<svg xmlns="http://www.w3.org/2000/svg" class="d-none">
  <symbol id="i-participants" viewBox="0 0 16 16">
    <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
  </symbol>
  <symbol id="i-star-fill" viewBox="0 0 16 16">
    <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
  </symbol>
  <symbol id="i-star" viewBox="0 0 16 16">
    <path d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.56.56 0 0 0-.163-.505L1.71 6.745l4.052-.576a.53.53 0 0 0 .393-.288L8 2.223l1.847 3.658a.53.53 0 0 0 .393.288l4.052.575-2.906 2.77a.56.56 0 0 0-.163.506l.694 3.957-3.686-1.894a.5.5 0 0 0-.461 0z"/>
  </symbol>
</svg>

<div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-3">

{% set year_max_qso = rounds_this_year ? max(rounds_this_year|map(round => round.cq + 0)) : 0 %}
{% for m in 1..12 %}
  {% set month_rounds = rounds_this_year
      |filter(round => round[0].date|date('n') == m)
      |sort((a, b) => a[0].date <=> b[0].date) %}
  <div class="col">
    <div class="card h-100">
      <div class="card-title py-1 text-center fw-bold">
        <h5 class="card-title py-1">{{ ('months.m' ~ m)|trans }}</h5>
      </div>
      <ul class="list-group list-group-flush">
      {% for round in month_rounds %}
        <li class="list-group-item py-1 px-2">
          <div class="d-flex align-items-baseline">
            <a class="fw-bold text-decoration-none py-1" href="{{
                path('round', { 'date': round[0].date|date('Y-m-d') })
            }}" title="{{ round[0].date|date('Y-m-d') }}">{{ round[0].name }}</a>
            <span class="text-muted text-nowrap text-center ms-2 flex-grow-1"{% if round[0].name == 'Microwave' %} style="transform: translateX(-22px)"{% endif %}>{{ round[0].date|date('Y-m-d') }}</span>
            <span class="text-nowrap ms-2" title="{% trans %}lyac.rounds.participants{% endtrans %}: {{ round.c }}">
              <svg width="12" height="12" fill="currentColor" aria-hidden="true"><use href="#i-participants"/></svg>{{ round.c }}
            </span>
            <!-- span class="text-nowrap ms-2" title="{% trans %}lyac.rounds.qso{% endtrans %}: {{ round.cq }}">{{ round.cq }}</span -->
          </div>
          <div class="progress mt-1" style="height: 12px;"
               title="{% trans %}lyac.rounds.qso{% endtrans %}: {{ round.cq }}">
            <div class="progress-bar bg-default" role="progressbar"
                 style="width: {{ year_max_qso ? (round.cq / year_max_qso * 100)|round : 0 }}%"
                 aria-valuenow="{{ round.cq }}"
                 aria-valuemin="0" aria-valuemax="{{ year_max_qso }}"></div>
          </div>
          {% set stars = max(1, (round.complete * 5)|round(0, 'ceil')) %}
          <div class="text-primary text-center py-1 mt-1" style="line-height: 1;"
               title="{% trans %}term.percentage_logs{% endtrans %}: {{ (round.complete * 100)|round }}%">
            {% for i in 1..5 %}
            <svg width="15" height="15" fill="currentColor" aria-hidden="true"><use href="#i-star{{ i <= stars ? '-fill' }}"/></svg>
            {% endfor %}
          </div>
        </li>
      {% else %}
        <li class="list-group-item py-1 px-2 text-center text-muted">&mdash;</li>
      {% endfor %}
      </ul>
    </div>
  </div>
{% endfor %}

</div>
