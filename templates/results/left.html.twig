<div class="card sidebar-sticky">

  <div class="card-body">
    <h5 class="card-title">{% trans %}lyac.results.title{% endtrans %}</h5>
    <p class="card-text">{% trans %}lyac.results.subtitle{% endtrans %}</p>
      <div class="btn-group-vertical sidebar-dropdowns">
      {% for year, rounds in years %}
        <div class="btn-group dropend">
          <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
          {{ year }}
          </button>
          <div class="dropdown-menu">
            <a class="dropdown-item" href="{{ path('top_scores_all', { 'year': year }) }}">{% trans %}yearly_top{% endtrans %}</a>
            <div class="dropdown-divider"></div>
          {% for round in rounds %}
            <a class="dropdown-item" href="{{ path('results', { 'year': year, 'band': round } )}}">{{ round }} </a>
          {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>
